FROM registry.access.redhat.com/ubi9/python-312 as builder
ARG EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
ARG AAP_VERSION=2.6

WORKDIR /rag-content
USER 0

COPY aap-product-docs-plaintext ./aap-product-docs-plaintext
COPY additional_docs ./additional_docs

COPY scripts/custom_processor-aap.py .
COPY requirements.txt ./requirements.txt
COPY embeddings_model ./embeddings_model
COPY src/aap_rag_content ./aap_rag_content

RUN python3.12 -m venv .venv
RUN pip3.12 install --upgrade pip
RUN pip3.12 install --no-cache-dir --extra-index-url https://download.pytorch.org/whl/cpu -r requirements.txt

RUN cd embeddings_model; if [ ! -f model.safetensors ]; then  \
        curl -L -O https://huggingface.co/sentence-transformers/all-mpnet-base-v2/resolve/9a3225965996d404b775526de6dbfe85d3368642/model.safetensors; \
    fi

ENV PYTHONPATH=/rag-content
RUN python custom_processor-aap.py  \
  -o ./llama_stack_vector_db \
  -f /rag-content \
  -md embeddings_model/ \
  -mn ${EMBEDDING_MODEL} \
  -i aap-product-docs-$(echo $AAP_VERSION | sed 's/\./_/g') \
  --vector-store-type=llamastack-faiss \
  -c 200 \
  -l 10

WORKDIR /rag-content/llama_stack_vector_db
RUN gzip faiss_store.db; sha256sum faiss_store.db.gz > faiss_store.db.gz.sha256
RUN sed -n 's/.*vector_store_id: //p' llama-stack.yaml | tr -d '\n' > provider_vector_db_id.ind

FROM registry.access.redhat.com/ubi9/ubi-minimal@sha256:6fc28bcb6776e387d7a35a2056d9d2b985dc4e26031e98a2bd35a7137cd6fd71

# install diff and gzip
RUN microdnf install -y diffutils gzip

COPY --from=builder /rag-content/embeddings_model /rag/embeddings_model
COPY --from=builder /rag-content/llama_stack_vector_db /rag/llama_stack_vector_db

# this directory is checked by ecosystem-cert-preflight-checks task in Konflux
RUN mkdir /licenses
COPY LICENSE /licenses/

# Labels for enterprise contract
LABEL com.redhat.component=aap-rag-content
LABEL description="Red Hat Ansible Automation Platform RAG content"
LABEL distribution-scope=private
LABEL io.k8s.description="Red Hat Ansible Automation Platform RAG content"
LABEL io.k8s.display-name="Ansible Automation Platform RAG content"
LABEL io.ansible.tags="ansible,aap,ai,assistant,rag"
LABEL name=aap-rag-content
LABEL release=0.0.1
LABEL url="https://github.com/ansible/aap-rag-content"
LABEL vendor="Red Hat"
LABEL version=0.0.1
LABEL summary="Red Hat Ansible Automation Platform RAG content"

COPY entrypoint.sh /rag
RUN chmod +x /rag/entrypoint.sh

USER 65532:65532
