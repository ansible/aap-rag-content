FROM registry.access.redhat.com/ubi9/python-312 as aap-rag-builder
ARG EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
ARG FLAVOR=cpu
ARG HERMETIC=false
ARG AAP_VERSION=2.5

USER 0
WORKDIR /workdir

COPY requirements-modified.txt ./requirements.txt

COPY aap-product-docs-plaintext ./aap-product-docs-plaintext
COPY additional_docs ./additional_docs

COPY embeddings_model ./embeddings_model

COPY scripts/generate_embeddings-aap.py .
COPY scripts/generate_embeddings-llama-stack.py .
COPY run.yaml .

RUN python3.12 -m venv .venv
RUN source .venv/bin/activate
RUN pip3.12 install --no-cache-dir -r requirements.txt

RUN cd embeddings_model; if [ "$HERMETIC" == "true" ]; then \
        cp /cachi2/output/deps/generic/model.safetensors model.safetensors; \
    else \
        curl -L -O https://huggingface.co/sentence-transformers/all-mpnet-base-v2/resolve/9a3225965996d404b775526de6dbfe85d3368642/model.safetensors; \
    fi

RUN set -e && python3.12 generate_embeddings-aap.py \
  -f aap-product-docs-plaintext \
  -mn ${EMBEDDING_MODEL} \
  -o vector_db/aap_product_docs/${AAP_VERSION} \
  -i aap-product-docs-$(echo $AAP_VERSION | sed 's/\./_/g') \
  -v ${AAP_VERSION} \
  -c 200 \
  -l 10

RUN set -e && python3.12 generate_embeddings-llama-stack.py \
  -f aap-product-docs-plaintext \
  -i aap-product-docs-$(echo $AAP_VERSION | sed 's/\./_/g') \
  -c 200

RUN cd llama_stack_vector_db; gzip faiss_store.db; sha256sum faiss_store.db.gz > faiss_store.db.gz.sha256

FROM registry.access.redhat.com/ubi9/ubi-minimal@sha256:e12131db2e2b6572613589a94b7f615d4ac89d94f859dad05908aeb478fb090f

# install diff and gzip
RUN microdnf install -y diffutils gzip

COPY --from=aap-rag-builder /workdir/vector_db/aap_product_docs /rag/vector_db/aap_product_docs
COPY --from=aap-rag-builder /workdir/embeddings_model /rag/embeddings_model
COPY --from=aap-rag-builder /workdir/llama_stack_vector_db /rag/llama_stack_vector_db

# this directory is checked by ecosystem-cert-preflight-checks task in Konflux
RUN mkdir /licenses
COPY LICENSE /licenses/

# Labels for enterprise contract
LABEL com.redhat.component=aap-rag-content
LABEL description="Red Hat Ansible Automation Platform RAG content"
LABEL distribution-scope=private
LABEL io.k8s.description="Red Hat Ansible Automation Platform RAG content"
LABEL io.k8s.display-name="Ansible Automation Platform RAG content"
LABEL io.ansible.tags="ansible,aap,ai,assistant,rag"
LABEL name=aap-rag-content
LABEL release=0.0.1
LABEL url="https://github.com/ansible/aap-rag-content"
LABEL vendor="Red Hat"
LABEL version=0.0.1
LABEL summary="Red Hat Ansible Automation Platform RAG content"

COPY entrypoint.sh /rag
RUN chmod +x /rag/entrypoint.sh

USER 65532:65532
